<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Retseptiraamat.NimekiriLeht"
             Title="Minu retseptid"
             BackgroundColor="#F5F5F5">

    <ListView x:Name="listView"
              IsGroupingEnabled="True"
              HasUnevenRows="True"
              SeparatorVisibility="None">

        <!-- ГРУППА -->
        <ListView.GroupHeaderTemplate>
            <DataTemplate>
                <ViewCell>
                    <Frame BackgroundColor="#4CAF50"
                           Padding="10"
                           CornerRadius="10"
                           Margin="10,5">
                        <Label Text="{Binding Nimetus}"
                               TextColor="White"
                               FontSize="18"
                               FontAttributes="Bold"/>
                    </Frame>
                </ViewCell>
            </DataTemplate>
        </ListView.GroupHeaderTemplate>

        <!-- ЭЛЕМЕНТ -->
        <ListView.ItemTemplate>
            <DataTemplate>
                <ViewCell>

                    <!-- Swipe menu -->
                    <ViewCell.ContextActions>
                        <MenuItem Text="Kustuta"
                                  IsDestructive="True"
                                  Clicked="Kustuta_Clicked"/>
                    </ViewCell.ContextActions>

                    <Frame Margin="10,5"
                           Padding="10"
                           CornerRadius="15"
                           BackgroundColor="White"
                           HasShadow="True">

                        <Grid ColumnDefinitions="80,*">

                            <Image Source="{Binding PildiLink}"
                                   WidthRequest="70"
                                   HeightRequest="70"
                                   Aspect="AspectFill"/>

                            <VerticalStackLayout Grid.Column="1"
                                                 VerticalOptions="Center"
                                                 Spacing="5">

                                <Label Text="{Binding Nimi}"
                                       FontSize="16"
                                       FontAttributes="Bold"/>

                                <Label Text="{Binding Kategooria}"
                                       FontSize="12"
                                       TextColor="Gray"/>
                            </VerticalStackLayout>

                        </Grid>

                    </Frame>
                </ViewCell>
            </DataTemplate>
        </ListView.ItemTemplate>

    </ListView>
</ContentPage>