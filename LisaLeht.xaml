<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Retseptiraamat.LisaLeht"
             Title="Lisa retsept"
             BackgroundColor="#0F172A">

    <ScrollView>

        <VerticalStackLayout Padding="20" Spacing="15">

            <Label Text="➕ Lisa retsept"
                   FontSize="30"
                   FontAttributes="Bold"
                   TextColor="White"/>

            <Entry x:Name="nimiEntry"
                   Placeholder="Retsepti nimi"
                   TextColor="White"
                   PlaceholderColor="Gray"/>

            <Entry x:Name="kategooriaEntry"
                   Placeholder="Kategooria"
                   TextColor="White"
                   PlaceholderColor="Gray"/>

            <Button Text="📷 Vali pilt"
                    Clicked="ValiPilt_Clicked"
                    BackgroundColor="#2563EB"
                    TextColor="White"/>

            <Image x:Name="previewImage"
                   HeightRequest="200"
                   Aspect="AspectFill"/>

            <Button Text="💾 Salvesta"
                    Clicked="Salvesta_Clicked"
                    BackgroundColor="#22C55E"
                    TextColor="White"/>

        </VerticalStackLayout>

    </ScrollView>

</ContentPage>